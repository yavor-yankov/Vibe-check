# Copy to .env.local and fill in. Never commit .env.local.

# ---------------------------------------------------------------------------
# LLM + search (existing)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=                 # https://aistudio.google.com/apikey
# Optional: override the Gemini model globally. When unset, we pick per-plan:
#   free/anon → gemini-2.5-flash-lite (higher free-tier quota bucket)
#   pro / lifetime → gemini-2.5-flash (better reasoning)
# Set this to force one model for everyone (useful when rate-limited).
# GEMINI_MODEL=gemini-2.5-flash

TAVILY_API_KEY=                 # https://app.tavily.com/home

# ---------------------------------------------------------------------------
# App URL (required for correct magic-link / OAuth redirects)
# ---------------------------------------------------------------------------
# Set to the canonical origin of your deployment — no trailing slash.
# Examples:
#   Local dev:  http://localhost:3000
#   Production: https://vibe-check.vercel.app
#
# IMPORTANT — Supabase Allowed Redirect URLs:
#   Go to Supabase Dashboard → Authentication → URL Configuration and add:
#     <NEXT_PUBLIC_APP_URL>/auth/callback
#   If you have multiple Supabase projects, failing to do this causes magic
#   links to redirect to the wrong project's Site URL.
NEXT_PUBLIC_APP_URL=            # https://your-app.vercel.app (or http://localhost:3000)

# ---------------------------------------------------------------------------
# Supabase (PR-A)
# ---------------------------------------------------------------------------
# Create a project at https://supabase.com/dashboard/new, then copy the
# values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=       # https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon public key — safe to ship to the browser
SUPABASE_SERVICE_ROLE_KEY=      # service_role secret key — SERVER ONLY, bypasses RLS

# ---------------------------------------------------------------------------
# Stripe (PR-C — monetization)
# ---------------------------------------------------------------------------
# Test keys: https://dashboard.stripe.com/test/apikeys
# Create two products in https://dashboard.stripe.com/test/products:
#   - "Vibe Check Pro"      → $9/mo recurring → copy the price id below
#   - "Vibe Check Lifetime" → $49 one-time    → copy the price id below
# The webhook secret comes from `stripe listen --forward-to http://localhost:3000/api/billing/webhook`
# locally, or from the Stripe dashboard → Developers → Webhooks in prod.
STRIPE_SECRET_KEY=              # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=          # whsec_...
STRIPE_PRICE_PRO=               # price_... (recurring, monthly)
STRIPE_PRICE_LIFETIME=          # price_... (one-time)

# ---------------------------------------------------------------------------
# Branded transactional email via Resend (optional but strongly recommended)
# ---------------------------------------------------------------------------
# Sign up at https://resend.com — free tier includes 3,000 emails/month.
# Without this, magic links still work but use Supabase's plain template.
#
# Steps:
#   1. Create a free account at https://resend.com
#   2. Add & verify your sending domain (or use @resend.dev for testing)
#   3. Create an API key with "Sending access"
#   4. Set EMAIL_FROM to your verified address (e.g. hello@yourdomain.com)
RESEND_API_KEY=                 # re_...
EMAIL_FROM=                     # Vibe Check <noreply@yourdomain.com>

# ---------------------------------------------------------------------------
# Rate limiting (optional — gracefully disabled when absent)
# ---------------------------------------------------------------------------
# Create a free Redis database at https://console.upstash.com and copy the
# REST URL + token below. Without these the rate limiter is silently disabled.
# In production it enforces 20 requests per minute per user on all AI routes.
UPSTASH_REDIS_REST_URL=         # https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=       # your-upstash-token
