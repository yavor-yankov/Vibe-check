# Copy to .env.local and fill in. Never commit .env.local.

# ---------------------------------------------------------------------------
# LLM + search (existing)
# ---------------------------------------------------------------------------
GEMINI_API_KEY=                 # https://aistudio.google.com/apikey
# Optional: override the Gemini model globally. When unset, we pick per-plan:
#   free/anon → gemini-2.5-flash-lite (higher free-tier quota bucket)
#   pro / lifetime → gemini-2.5-flash (better reasoning)
# Set this to force one model for everyone (useful when rate-limited).
# GEMINI_MODEL=gemini-2.5-flash

TAVILY_API_KEY=                 # https://app.tavily.com/home

# ---------------------------------------------------------------------------
# Supabase (PR-A)
# ---------------------------------------------------------------------------
# Create a project at https://supabase.com/dashboard/new, then copy the
# values from Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=       # https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # anon public key — safe to ship to the browser
SUPABASE_SERVICE_ROLE_KEY=      # service_role secret key — SERVER ONLY, bypasses RLS

# ---------------------------------------------------------------------------
# Stripe (PR-C — monetization)
# ---------------------------------------------------------------------------
# Test keys: https://dashboard.stripe.com/test/apikeys
# Create two products in https://dashboard.stripe.com/test/products:
#   - "Vibe Check Pro"      → $9/mo recurring → copy the price id below
#   - "Vibe Check Lifetime" → $49 one-time    → copy the price id below
# The webhook secret comes from `stripe listen --forward-to http://localhost:3000/api/billing/webhook`
# locally, or from the Stripe dashboard → Developers → Webhooks in prod.
STRIPE_SECRET_KEY=              # sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=          # whsec_...
STRIPE_PRICE_PRO=               # price_... (recurring, monthly)
STRIPE_PRICE_LIFETIME=          # price_... (one-time)
